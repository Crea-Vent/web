rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Actualités : lecture publique, écriture réservée à l'admin connecté
    match /actualites/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Fiches : création publique (salariés soumettent sans compte),
    //          lecture/modification/suppression réservées à l'admin connecté
    match /fiches/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Toute autre collection : accès refusé par défaut
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
